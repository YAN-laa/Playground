APP_STORE=memory
APP_SEARCH=local
NDR_SERVER_ADDR=:8080
NDR_BUFFER_DIR=./probe-buffer
NDR_BUFFER_MAX_FILES=200
NDR_BUFFER_MAX_BYTES=67108864
