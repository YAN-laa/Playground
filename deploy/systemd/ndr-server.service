[Unit]
Description=NDR Server
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=ndr
Group=ndr
WorkingDirectory=/opt/ndr
EnvironmentFile=/etc/ndr/server.env
ExecStart=/opt/ndr/bin/ndr-server
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
